{
  "name": "zh-tools",
  "version": "0.1.0",
  "description": "前端常用工具方法库 — 上传、下载、日期格式化、图片处理、请求封装",
  "type": "module",
  "main": "./dist/zh-tools.cjs",
  "module": "./dist/zh-tools.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/zh-tools.js",
      "require": "./dist/zh-tools.cjs",
      "types": "./dist/index.d.ts"
    },
    "./src/*": {
      "import": "./src/*",
      "default": "./src/*"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "preview": "node -e \"console.log('zh-tools v' + require('./package.json').version)\""
  },
  "keywords": [
    "utils",
    "upload",
    "download",
    "date",
    "image",
    "tools",
    "request",
    "axios",
    "前端工具",
    "工具方法"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^3.2.0",
    "happy-dom": "^17.0.0",
    "axios": "^1.7.0"
  }
}
